<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            xmlns:tools="http://schemas.android.com/tools"
            style="@style/StyleDialog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:focusableInTouchMode="true"
            tools:context=".dialogs.CareDialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Заголовок -->
        <RelativeLayout
            style="@style/StyleDialogHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_actions_profileswitch" />

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_gravity="center"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:text="@string/careportal_profileswitch"
                android:textAlignment="center"
                android:textAppearance="?android:attr/textAppearanceLarge" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/spacer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="5dp" />

        <LinearLayout
            android:id="@+id/activity_v2_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone"
            tools:ignore="HardcodedText"
            tools:visibility="visible">

            <LinearLayout
                android:id="@+id/activity_current_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/activity_current_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:textAppearance="@style/TextAppearance.AppCompat.Small"
                    android:textStyle="bold"
                    tools:text="Активна WALK: идет 30 мин, хвост 0 мин" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/activity_end_now"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Завершить" />

                    <Button
                        android:id="@+id/activity_cancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Отменить" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Тип нагрузки"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/activity_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/activity_mode_walk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="WALK" />

                <RadioButton
                    android:id="@+id/activity_mode_sport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPORT" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:text="Длительность"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/activity_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/activity_duration_30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="30 мин" />

                <RadioButton
                    android:id="@+id/activity_duration_50"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 мин" />

                <RadioButton
                    android:id="@+id/activity_duration_90"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="90 мин" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:text="Старт"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="false">

                <RadioGroup
                    android:id="@+id/activity_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/activity_start_now"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="сейчас" />

                    <RadioButton
                        android:id="@+id/activity_start_20"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+20" />

                    <RadioButton
                        android:id="@+id/activity_start_30"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+30" />

                    <RadioButton
                        android:id="@+id/activity_start_50"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+50" />

                    <RadioButton
                        android:id="@+id/activity_start_60"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+60" />
                </RadioGroup>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/activity_carbs_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/activity_carbs_needed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.AppCompat.Small"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/activity_carb_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/activity_carbs_fast"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="быстрые" />

                    <RadioButton
                        android:id="@+id/activity_carbs_normal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="обычные" />
                </RadioGroup>

                <CheckBox
                    android:id="@+id/activity_confirm_carbs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Я приму эти углеводы" />
            </LinearLayout>

            <TextView
                android:id="@+id/activity_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="8dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />
        </LinearLayout>

        <!-- выбор профиля (Саргис) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:hint="@string/profile">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/profileList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/reuselayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:visibility="gone">

            <app.aaps.core.ui.elements.SingleClickButton
                android:id="@+id/reusebutton"
                style="@style/ButtonSmallFontStyle"
                android:drawablePadding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_clone" />
        </LinearLayout>

        <!-- выбор источника BG (блок из Мэтью, но без кастомного стиля, чтобы не ловить крэши) -->
        <RadioGroup
            android:id="@+id/bgsource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/meter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="@string/bg_meter" />

            <RadioButton
                android:id="@+id/sensor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/bg_sensor" />

            <RadioButton
                android:id="@+id/other"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bg_other" />
        </RadioGroup>

        <!-- sport duty (из Мэтью, id такие же как у Саргиса) -->
        <LinearLayout
            android:id="@+id/sport_duty_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                android:gravity="center_horizontal|center_vertical"
                tools:ignore="UseSwitchCompatOrMaterialXml">

                <TextView
                    android:id="@+id/sport_duty_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center_horizontal"
                    android:padding="10dp"
                    android:textAppearance="@style/TextAppearance.AppCompat.Small"
                    android:textStyle="bold"
                    android:text="@string/sport_duty_options_label" />

                <Switch
                    android:id="@+id/switch_duty_options"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:checked="true" />
            </LinearLayout>

            <RadioGroup
                android:id="@+id/sport_duty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/duty_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/duty_option_light" />

                <RadioButton
                    android:id="@+id/duty_middle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:text="@string/duty_option_middle" />

                <RadioButton
                    android:id="@+id/duty_heavy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/duty_option_heavy" />
            </RadioGroup>
        </LinearLayout>

        <!-- BG -->
        <LinearLayout
            android:id="@+id/bg_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bg_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:width="120dp"
                android:padding="10dp"
                android:text="@string/bg_label"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <app.aaps.core.ui.elements.NumberPicker
                android:id="@+id/bg"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:layout_marginBottom="2dp"
                app:customContentDescription="@string/bg_label" />

            <TextView
                android:id="@+id/bg_units"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="start"
                android:minWidth="45dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:text="@string/mgdl"
                android:textAppearance="?android:attr/textAppearanceSmall" />
        </LinearLayout>

        <!-- Длительность -->
        <LinearLayout
            android:id="@+id/duration_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/duration_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:width="120dp"
                android:padding="10dp"
                android:text="@string/duration_label"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <app.aaps.core.ui.elements.MinutesNumberPicker
                android:id="@+id/duration"
                android:layout_width="130dp"
                android:layout_height="40dp"
                app:customContentDescription="@string/duration_label" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="start"
                android:minWidth="45dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:text="@string/unit_minute_short"
                android:textAppearance="?android:attr/textAppearanceSmall" />
        </LinearLayout>

        <RadioGroup
            android:id="@+id/sport_duration_presets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/duration_30"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="@string/duration_preset_30" />

            <RadioButton
                android:id="@+id/duration_50"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="@string/duration_preset_50" />

            <RadioButton
                android:id="@+id/duration_80"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duration_preset_80" />
        </RadioGroup>

        <!-- sargius added from profile switch dialog -->
        <LinearLayout
            android:id="@+id/percentage_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/percentage_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:width="120dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/percentage_label"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <app.aaps.core.ui.elements.NumberPicker
                android:id="@+id/percentage"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:layout_marginBottom="2dp"
                app:customContentDescription="@string/percentage_label" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="start"
                android:minWidth="45dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:text="%"
                android:textAppearance="?android:attr/textAppearanceSmall"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/timeshift_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/timeshift_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:width="120dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/timeshift_label"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <app.aaps.core.ui.elements.NumberPicker
                android:id="@+id/timeshift"
                android:layout_width="130dp"
                android:layout_height="40dp"
                app:customContentDescription="@string/timeshift_label" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="start"
                android:minWidth="45dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:text="@string/unit_minutes"
                android:textAppearance="?android:attr/textAppearanceSmall" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tt_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:width="120dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/temporary_target"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/tt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:checked="true"
                android:text="@string/activity" />
        </LinearLayout>

        <!-- заметки / время / ОК-Отмена -->
        <include
            android:id="@+id/notes_layout"
            layout="@layout/notes" />

        <include
            android:id="@+id/datetime"
            layout="@layout/datetime" />

        <include
            android:id="@+id/okcancel"
            layout="@layout/okcancel" />
    </LinearLayout>

</ScrollView>
